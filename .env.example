# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WEB_URL=https://www.zeroops.in
# Internal API URL - must point to your running API server
# Dev: usually http://localhost:4000
# Prod: your deployed API URL e.g. https://api.zeroops.in
INTERNAL_API_URL=http://localhost:4000
API_BASE_URL=http://localhost:4000
API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_WHATSAPP=919746927368
# ZeroOps admin WhatsApp number (with country code, no +)

# reCAPTCHA
# Current production flow uses Google reCAPTCHA v3.
# Switch to checkbox only if you create a new v2 checkbox key pair.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
NEXT_PUBLIC_RECAPTCHA_MODE=v3
RECAPTCHA_SECRET_KEY=your_secret_key_here
RECAPTCHA_MIN_SCORE=0.5

# Google OAuth (no quotes around values!)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
CLIENT_ORIGIN=https://www.zeroops.in
WEB_BASE_URL=https://www.zeroops.in

# WhatsApp (Free - wa.me deep links, no SDK)
# WhatsApp: Using free wa.me links - no Twilio needed
