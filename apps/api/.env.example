PORT=4000
MONGODB_URI=mongodb://localhost:27017/zero-os
MONGODB_URI_FALLBACK=mongodb://127.0.0.1:27017/zero-os

JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRES_IN=7d
COOKIE_SECURE=false

RESEND_API_KEY=re_your_key_here
EMAIL_FROM=ZeroOps <onboarding@resend.dev>
ADMIN_NOTIFY_EMAIL=zerohub01@gmail.com

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

CLIENT_ORIGIN=http://localhost:3000
WEB_BASE_URL=https://www.zeroops.in

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Must match the Google reCAPTCHA property used by NEXT_PUBLIC_RECAPTCHA_SITE_KEY.
# Current production flow uses v3 with score-based verification.
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here
RECAPTCHA_MIN_SCORE=0.5

# Optional: set only if runtime Chrome is installed outside Puppeteer's default cache.
PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Preferred Meta Cloud API credentials
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_BUSINESS_ACCOUNT_ID=
META_API_VERSION=v18.0
WHATSAPP_BUSINESS_PHONE=+919746927368
WHATSAPP_API_ENABLED=true
META_WEBHOOK_URL=https://zero-api-m0an.onrender.com/webhook/whatsapp
META_WEBHOOK_VERIFY_TOKEN=
META_DEFAULT_TEMPLATE_NAME=
META_INVOICE_TEMPLATE_NAME=
META_TEMPLATE_LANGUAGE=en_US
WHATSAPP_DEFAULT_COUNTRY_CODE=91
# Backward-compatible aliases
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_SENDER_NUMBER=919746927368
# Backward-compatible alias (optional). If both are set, META_WEBHOOK_VERIFY_TOKEN takes precedence.
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# WhatsApp: Using free wa.me links - no Twilio needed

# Admin bank details (invoice prefill)
ZERO_BANK_NAME=HDFC Bank
ZERO_ACCOUNT_NUMBER=your_account_number
ZERO_IFSC_CODE=HDFC0000000
