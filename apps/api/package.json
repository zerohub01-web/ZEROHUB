{
  "name": "@zero/api",
  "version": "1.0.0",
  "private": true,
  "_whatsapp_strategy": "meta cloud api headless sending",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "verify:whatsapp": "node scripts/verify-meta-whatsapp.mjs",
    "diagnose:whatsapp": "node scripts/diagnose-meta-whatsapp.mjs",
    "smoke:whatsapp": "node scripts/whatsapp-smoke-check.mjs",
    "lint": "eslint . --ext .ts",
    "test:unit": "vitest run tests/unit --pool=threads",
    "test:api": "node test-results/api-tests.mjs"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.1",
    "morgan": "^1.10.0",
    "pdf-lib": "^1.17.1",
    "resend": "^4.8.0",
    "validator": "^13.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.5.4",
    "@types/puppeteer": "^5.4.7",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "cloudinary": {
      "lodash": "4.18.1"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    }
  }
}
